# .gitignore — Merapi Anomaly Detection

# Images (386 MB — non versionnées, éphémères sur Streamlit Cloud)
data/raw/
data/processed/

# Index backups (garder uniquement index.csv principal)
data/index/index*.csv
!data/index/index.csv

# Outputs LoRA (supprimés du projet — voir historique git si besoin)
outputs/lora_merapi/
outputs/lora_merapi_physics/
outputs/lora_merapi_results/
outputs/generated/

# Garder : index.csv, patchcore.npz, scores CSV, figures PNG/HTML
# outputs/models/patchcore.npz  → versionné (17 MB, dans la limite GitHub 100 MB)
# outputs/scores/               → versionné (3 MB)
# outputs/figures/              → versionné (PNG + HTML interactif timeline)

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.env

# IDE
.DS_Store
.vscode/
*.code-workspace

# Logs
logs/
*.log

# Notebooks checkpoints
.ipynb_checkpoints/

# Zips
*.zip
